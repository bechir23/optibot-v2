# ── LiveKit (self-hosted, free) ──────────────────────────
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# ── LLM Providers ───────────────────────────────────────
MISTRAL_API_KEY=your_mistral_api_key
GROQ_API_KEY=your_groq_api_key

# ── STT / TTS ───────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key
CARTESIA_API_KEY=your_cartesia_api_key

# ── Telephony (SIP trunk) ───────────────────────────────
TELNYX_API_KEY=your_telnyx_api_key
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=your_livekit_outbound_trunk_id
# Backward-compatible alias used by older code/docs. This should contain
# the LiveKit outbound trunk ID, not the Telnyx portal SIP Connection ID.
TELNYX_SIP_TRUNK_ID=your_livekit_outbound_trunk_id
TELNYX_SIP_CONNECTION_ID=your_telnyx_portal_sip_connection_id
TELNYX_OUTBOUND_PROFILE_ID=your_telnyx_outbound_voice_profile_id
TELNYX_USERNAME=your_telnyx_sip_username
SIP_DESTINATION_COUNTRY=FR
# Or Twilio:
# TWILIO_ACCOUNT_SID=your_twilio_sid
# TWILIO_AUTH_TOKEN=your_twilio_token
# TWILIO_PHONE_NUMBER=+33xxxxxxxxx

# ── Database ─────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key

# ── Infrastructure (auto-set by docker-compose) ─────────
REDIS_URL=redis://localhost:6379/0
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── Security ─────────────────────────────────────────────
API_KEY=generate_a_random_key_here
DOSSIER_ENCRYPTION_KEY=generate_with_python_cryptography_fernet

# ── Feature Flags ────────────────────────────────────────
ANSWER_SOFT_TIMEOUT_SEC=4.0
ANSWER_HARD_TIMEOUT_SEC=15.0
MAX_IVR_ATTEMPTS=5
MAX_CONCURRENT_CALLS=10
RECORDING_ENABLED=false
